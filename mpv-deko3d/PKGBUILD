# Contributor: Cpasjuste <cpasjuste@gmail.com>

pkgbasename=libmpv
pkgname=switch-${pkgbasename}-deko3d
pkgver=0.38.0
pkgrel=4
pkgdesc='Command line video player (library only)'
arch=('any')
url='https://mpv.io/'
license=('GPL')
options=(!strip libtool staticlibs)
source=(
  "${pkgbasename}-${pkgver}.tar.gz::https://github.com/mpv-player/mpv/archive/v${pkgver}.tar.gz" 
  "hos-audio.patch" "ass-fonts.patch" "mp-image.patch" "deko3d.patch"
)
sha256sums=(
  '86d9ef40b6058732f67b46d0bbda24a074fae860b3eaae05bab3145041303066'
  'SKIP' 'SKIP' 'SKIP' 'SKIP'
)
makedepends=("dkp-toolchain-vars" "dkp-meson-scripts")
depends=('switch-ffmpeg' 'switch-libplacebo' 'deko3d' 'libuam')
groups=('switch-portlibs')

prepare() {
  cd mpv-$pkgver
  rm -f audio/out/ao_hos.c osdep/switch/sys/mman.h
  patch -Np1 -i "$srcdir/hos-audio.patch"
  patch -Np1 -i "$srcdir/ass-fonts.patch"
  patch -Np1 -i "$srcdir/mp-image.patch"
  patch -Np1 -i "$srcdir/deko3d.patch"
}

build() {
  cd mpv-$pkgver

  /opt/devkitpro/meson-cross.sh switch ../crossfile.txt \
    -Dlibmpv=true -Dcplayer=false -Dtests=false \
    -Dgl=disabled -Degl=disabled -Dsdl2=disabled -Diconv=disabled  \
    -Dlibarchive=disabled -Dlua=disabled -Djpeg=disabled \
    -Dhos-audio=enabled -Ddeko3d=enabled build

  meson compile -C build
}

package() {
  cd mpv-$pkgver

  DESTDIR="$pkgdir" meson install -C build
}